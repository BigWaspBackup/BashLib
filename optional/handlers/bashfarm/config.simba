  WriteINI(sec, 'Ortus herb', ToStr(Self.Enabled[EBASHFarmPatch.ORTUS_HERB]), path);
  WriteINI(sec, 'Ortus flower', ToStr(Self.Enabled[EBASHFarmPatch.ORTUS_FLOWER]), path);
  WriteINI(sec, 'Ortus allot N', ToStr(Self.Enabled[EBASHFarmPatch.ORTUS_ALLOT_N]), path);
  WriteINI(sec, 'Ortus allot S', ToStr(Self.Enabled[EBASHFarmPatch.ORTUS_ALLOT_S]), path);
  WriteINI(sec, 'Guild herb', ToStr(Self.Enabled[EBASHFarmPatch.GUILD_HERB]), path);
  WriteINI(sec, 'Guild flower', ToStr(Self.Enabled[EBASHFarmPatch.GUILD_FLOWER]), path);
  WriteINI(sec, 'Guild allot N', ToStr(Self.Enabled[EBASHFarmPatch.GUILD_ALLOT_N]), path);
  WriteINI(sec, 'Guild allot S', ToStr(Self.Enabled[EBASHFarmPatch.GUILD_ALLOT_S]), path);
  WriteINI(sec, 'Guild bush', ToStr(Self.Enabled[EBASHFarmPatch.GUILD_BUSH]), path);
  WriteINI(sec, 'Guild cactus', ToStr(Self.Enabled[EBASHFarmPatch.GUILD_CACTUS]), path);
  WriteINI(sec, 'Guild anima', ToStr(Self.Enabled[EBASHFarmPatch.GUILD_ANIMA]), path);
  WriteINI(sec, 'Lumbridge tree', ToStr(Self.Enabled[EBASHFarmPatch.LUMBRIDGE_TREE]), path);
  WriteINI(sec, 'Varrock tree', ToStr(Self.Enabled[EBASHFarmPatch.VARROCK_TREE]), path);
  WriteINI(sec, 'Falador tree', ToStr(Self.Enabled[EBASHFarmPatch.FALADOR_TREE]), path);
  WriteINI(sec, 'Taverley tree', ToStr(Self.Enabled[EBASHFarmPatch.TAVERLEY_TREE]), path);
  WriteINI(sec, 'Gnome tree', ToStr(Self.Enabled[EBASHFarmPatch.GNOME_TREE]), path);
  WriteINI(sec, 'Guild tree', ToStr(Self.Enabled[EBASHFarmPatch.GUILD_TREE]), path);
  WriteINI(sec, 'Guild redwood', ToStr(Self.Enabled[EBASHFarmPatch.GUILD_REDWOOD]), path);
  WriteINI(sec, 'Gnome stronghold fruit', ToStr(Self.Enabled[EBASHFarmPatch.GNOME_STRONGHOLD_FRUIT]), path);
  WriteINI(sec, 'Catherby fruit', ToStr(Self.Enabled[EBASHFarmPatch.CATHERBY_FRUIT]), path);
  WriteINI(sec, 'Gnome village fruit', ToStr(Self.Enabled[EBASHFarmPatch.GNOME_VILLAGE_FRUIT]), path);
  WriteINI(sec, 'Brimhaven fruit', ToStr(Self.Enabled[EBASHFarmPatch.BRIMHAVEN_FRUIT]), path);
  WriteINI(sec, 'Lletya fruit', ToStr(Self.Enabled[EBASHFarmPatch.LLETYA_FRUIT]), path);
  WriteINI(sec, 'Guild fruit', ToStr(Self.Enabled[EBASHFarmPatch.GUILD_FRUIT]), path);

  WriteINI(sec, 'Barb dibber', ToStr(Self.BarbDibber), path);
  WriteINI(sec, 'Magic secs', ToStr(Self.MagicSecateurs), path);
  WriteINI(sec, 'Lumby elite', ToStr(Self.LumbyElite), path);
  WriteINI(sec, 'Run now', ToStr(Self.RunNow), path);
end;
