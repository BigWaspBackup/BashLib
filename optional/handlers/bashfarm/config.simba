  WriteINI(sec, 'Phasmatys flower', ToStr(Self.Enabled[EBASHFarmPatch.PHASMATYS_FLOWER]), path);
  WriteINI(sec, 'Phasmatys allot N', ToStr(Self.Enabled[EBASHFarmPatch.PHASMATYS_ALLOT_N]), path);
  WriteINI(sec, 'Phasmatys allot S', ToStr(Self.Enabled[EBASHFarmPatch.PHASMATYS_ALLOT_S]), path);
  WriteINI(sec, 'Hosidius herb', ToStr(Self.Enabled[EBASHFarmPatch.HOSIDIUS_HERB]), path);
  WriteINI(sec, 'Hosidius flower', ToStr(Self.Enabled[EBASHFarmPatch.HOSIDIUS_FLOWER]), path);
