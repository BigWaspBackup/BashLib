function BASHFarmTravelForPatch(patchId: EBASHFarmPatch; cfg: TBASHFarmConfig): TTeleportLocation;
begin
  case patchId of
    EBASHFarmPatch.WEISS_HERB:
      Exit(BASHFarmTravel_Weiss(cfg.WeissTP));
    EBASHFarmPatch.STRONGHOLD_HERB:
      Exit(BASHFarmTravel_Stronghold(cfg.StrongholdTP));
    EBASHFarmPatch.ARDOUGNE_HERB, EBASHFarmPatch.ARDOUGNE_FLOWER,
    EBASHFarmPatch.ARDOUGNE_ALLOT_N, EBASHFarmPatch.ARDOUGNE_ALLOT_S:
      Exit(BASHFarmTravel_Ardougne(cfg.ArdougneTP));
    EBASHFarmPatch.FALADOR_HERB, EBASHFarmPatch.FALADOR_FLOWER,
    EBASHFarmPatch.FALADOR_ALLOT_N, EBASHFarmPatch.FALADOR_ALLOT_S:
      Exit(BASHFarmTravel_Falador(cfg.FaladorTP));
    EBASHFarmPatch.CATHERBY_HERB, EBASHFarmPatch.CATHERBY_FLOWER,
    EBASHFarmPatch.CATHERBY_ALLOT_N, EBASHFarmPatch.CATHERBY_ALLOT_S:
      Exit(BASHFarmTravel_Catherby(cfg.CatherbyTP));
    EBASHFarmPatch.PHASMATYS_HERB, EBASHFarmPatch.PHASMATYS_FLOWER,
    EBASHFarmPatch.PHASMATYS_ALLOT_N, EBASHFarmPatch.PHASMATYS_ALLOT_S:
      Exit(BASHFarmTravel_Phasmatys(cfg.PhasmatysTP));
    EBASHFarmPatch.HOSIDIUS_HERB, EBASHFarmPatch.HOSIDIUS_FLOWER,
    EBASHFarmPatch.HOSIDIUS_ALLOT_N, EBASHFarmPatch.HOSIDIUS_ALLOT_S:
      Exit(BASHFarmTravel_Hosidius(cfg.HosidiusTP));
    EBASHFarmPatch.ORTUS_HERB, EBASHFarmPatch.ORTUS_FLOWER,
    EBASHFarmPatch.ORTUS_ALLOT_N, EBASHFarmPatch.ORTUS_ALLOT_S:
      Exit(BASHFarmTravel_Ortus(cfg.OrtusTP));
    EBASHFarmPatch.GUILD_HERB, EBASHFarmPatch.GUILD_FLOWER,
    EBASHFarmPatch.GUILD_ALLOT_N, EBASHFarmPatch.GUILD_ALLOT_S,
    EBASHFarmPatch.GUILD_BUSH, EBASHFarmPatch.GUILD_CACTUS,
    EBASHFarmPatch.GUILD_ANIMA, EBASHFarmPatch.GUILD_TREE,
    EBASHFarmPatch.GUILD_REDWOOD, EBASHFarmPatch.GUILD_FRUIT,
    EBASHFarmPatch.GUILD_CELASTRUS:
      Exit(BASHFarmTravel_Guild(cfg.GuildTP));
    EBASHFarmPatch.LUMBRIDGE_TREE:
      Exit(BASHFarmTravel_LumbridgeTree(cfg.LumbridgeTreeTP));
    EBASHFarmPatch.VARROCK_TREE:
      Exit(BASHFarmTravel_VarrockTree(cfg.VarrockTreeTP));
    EBASHFarmPatch.FALADOR_TREE:
      Exit(BASHFarmTravel_FaladorTree(cfg.FaladorTreeTP));
    EBASHFarmPatch.TAVERLEY_TREE:
      Exit(BASHFarmTravel_TaverleyTree(cfg.TaverleyTreeTP));
    EBASHFarmPatch.GNOME_TREE:
      Exit(BASHFarmTravel_GnomeTree(cfg.GnomeTreeTP));
    EBASHFarmPatch.GNOME_STRONGHOLD_FRUIT:
      Exit(BASHFarmTravel_GnomeFruit(cfg.GnomeFruitTP));
    EBASHFarmPatch.GNOME_VILLAGE_FRUIT:
      Exit(BASHFarmTravel_GnomeVillageFruit(cfg.GnomeVillageFruitTP));
    EBASHFarmPatch.CATHERBY_FRUIT:
      Exit(BASHFarmTravel_CatherbyFruit(cfg.CatherbyFruitTP));
    EBASHFarmPatch.BRIMHAVEN_FRUIT:
      Exit(BASHFarmTravel_BrimhavenFruit(cfg.BrimhavenFruitTP));
    EBASHFarmPatch.LLETYA_FRUIT:
      Exit(BASHFarmTravel_LletyaFruit(cfg.LletyaFruitTP));
  end;

  // Harmony / unknown — fall back to guild
  Result := RSTeleportsV2.FARMING_GUILD;
end;
