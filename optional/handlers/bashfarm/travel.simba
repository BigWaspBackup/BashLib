function BASHFarmTravelClamp(idx: Int32; options: TStringArray): Int32;
begin
  if Length(options) = 0 then
    Exit(0);
  if idx < 0 then
    Exit(0);
  if idx > High(options) then
    Exit(High(options));
  Result := idx;
end;

function BASHFarmTravel_Weiss(idx: Int32): TTeleportLocation;
begin
  case BASHFarmTravelClamp(idx, BASH_TRAVEL_WEISS) of
    1: Exit(RSTeleportsV2.NEXUS_WEISS);
  end;
  Result := RSTeleportsV2.WEISS;
end;

function BASHFarmTravel_Stronghold(idx: Int32): TTeleportLocation;
begin
  case BASHFarmTravelClamp(idx, BASH_TRAVEL_STRONGHOLD) of
    1: Exit(RSTeleportsV2.NEXUS_TROLL_STRONGHOLD);
  end;
  Result := RSTeleportsV2.TROLL_STRONGHOLD;
end;

function BASHFarmTravel_Ardougne(idx: Int32): TTeleportLocation;
begin
  case BASHFarmTravelClamp(idx, BASH_TRAVEL_ARDOUGNE) of
    1: Exit(RSTeleportsV2.ARDOUGNE); // cast spell (runes)
    2: Exit(setupTeleportLocation(ETeleportType.OTHER, ['Ardougne teleport'], 'Break', [6565, 37207])); // tablet
    3: Exit(RSTeleportsV2.NEXUS_ARDOUGNE);
  end;
  Result := RSTeleportsV2.ARDOUGNE_FARM_PATCH;
end;

function BASHFarmTravel_Falador(idx: Int32): TTeleportLocation;
begin
  case BASHFarmTravelClamp(idx, BASH_TRAVEL_FALADOR) of
    1: Exit(RSTeleportsV2.FALADOR); // cast spell (runes)
    2: Exit(setupTeleportLocation(ETeleportType.OTHER, ['Falador teleport'], 'Break', [7769, 37211])); // tablet
    3: Exit(RSTeleportsV2.NEXUS_FALADOR);
  end;
  Result := RSTeleportsV2.FALADOR_FARM_PATCH;
end;

function BASHFarmTravel_Catherby(idx: Int32): TTeleportLocation;
begin
  case BASHFarmTravelClamp(idx, BASH_TRAVEL_CATHERBY) of
    1: Exit(RSTeleportsV2.CAMELOT); // normal spell (runes)
    2: Exit(setupTeleportLocation(ETeleportType.OTHER, ['Camelot teleport'], 'Break', [6933, 37963]));
    3: Exit(setupTeleportLocation(ETeleportType.OTHER, ['Catherby teleport'], 'Break', [7164, 36566]));
    4: Exit(RSTeleportsV2.NEXUS_CATHERBY);
    5: Exit(RSTeleportsV2.NEXUS_CAMELOT);
  end;
  Result := RSTeleportsV2.CATHERBY; // Lunar spell (runes)
end;

function BASHFarmTravel_Phasmatys(idx: Int32): TTeleportLocation;
begin
  Result := RSTeleportsV2.ECTOFUNTUS; // Ectophial only
end;

function BASHFarmTravel_Hosidius(idx: Int32): TTeleportLocation;
begin
  case BASHFarmTravelClamp(idx, BASH_TRAVEL_HOSIDIUS) of
    1: Exit(RSTeleportsV2.HOSIDIUS_PORTAL);
    2: Exit(RSTeleportsV2.HOUSE); // Teleport to House spell — TeleportTo uses Outside
    3: Exit(setupTeleportLocation(ETeleportType.OTHER, ['Teleport to house'], 'Outside', [2868, 36222])); // house tablet → Outside
  end;
  // Book of the dead / Kharedst's — Reminisce → Lunch by the Lancalliums
  Result := RSTeleportsV2.LUNCH_BY_THE_LANCALLIUMS_HOSIDIUS;
end;

function BASHFarmTravel_Ortus(idx: Int32): TTeleportLocation;
begin
  case BASHFarmTravelClamp(idx, BASH_TRAVEL_ORTUS) of
    1:
      // Quetzal whistle → Hunter Guild → run north
      Exit(setupTeleportLocation(
        ETeleportType.OTHER,
        [
          'Perfected quetzal whistle(i)',
          'Perfected quetzal whistle',
          'Enhanced quetzal whistle',
          'Basic quetzal whistle'
        ],
        'Ortus Quetzal Whistle',
        BASH_ORTUS_HUNTER_LANDING
      ));
    2:
      // Civitas tablet → Renu Quetzal → Hunter Guild → run north
      Exit(setupTeleportLocation(
        ETeleportType.OTHER,
        ['Civitas illa fortis teleport'],
        'Ortus Civitas Tablet',
        BASH_ORTUS_HUNTER_LANDING
      ));
    3:
      // Civitas spell (1 fire, 1 earth, 2 law) → Renu → Guild → north
      Exit(setupTeleportLocation(
        ETeleportType.NORMAL_MAGIC,
        'Ortus Civitas Spell',
        0,
        BASH_ORTUS_HUNTER_LANDING
      ));
  end;

  // Hunter cape → Hunter Guild → run north
  Result := setupTeleportLocation(
    ETeleportType.OTHER,
    ['Hunter cape(t)', 'Hunter cape'],
    'Ortus Hunter Cape',
    BASH_ORTUS_HUNTER_LANDING
  );
end;

function BASHFarmTravel_Guild(idx: Int32): TTeleportLocation;
begin
  case BASHFarmTravelClamp(idx, BASH_TRAVEL_GUILD) of
    1: Exit(RSTeleportsV2.FARMING_GUILD_CAPE);
    2: Exit(setupTeleportLocation(
         ETeleportType.OTHER,
         [],
         'BASH Guild Fairy CIR',
         RSTeleportsV2.FARMING_GUILD.worldPoint
       ));
  end;
  // Skills necklace — Farming Guild (45+ Farming lands inside)
  Result := RSTeleportsV2.FARMING_GUILD;
end;

