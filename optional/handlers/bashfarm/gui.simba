  BASHFarmConfig.OrtusTP := Self.ReadComboIdx('lcb_bash_ortus_tp');
  BASHFarmConfig.GuildTP := Self.ReadComboIdx('lcb_bash_guild_tp');

  BASHFarmConfig.TreeSaplingIdx := Self.ReadComboIdx('lcb_bash_treesapling');
  BASHFarmConfig.FruitSaplingIdx := Self.ReadComboIdx('lcb_bash_fruitsapling');
  BASHFarmConfig.LumbridgeTreeTP := Self.ReadComboIdx('lcb_bash_lum_tree_tp');
