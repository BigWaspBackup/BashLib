  Self.AddCheck(Self.TreesSection, cb, 'cb_bash_gnome_fruit', 'Gnome stronghold', 24, y, BASHFarmConfig.Enabled[EBASHFarmPatch.GNOME_STRONGHOLD_FRUIT]);
  Self.AddCheck(Self.TreesSection, cb, 'cb_bash_cath_fruit', 'Catherby', 200, y, BASHFarmConfig.Enabled[EBASHFarmPatch.CATHERBY_FRUIT]);
  Self.AddCheck(Self.TreesSection, cb, 'cb_bash_gnome_village_fruit', 'Gnome village', 320, y, BASHFarmConfig.Enabled[EBASHFarmPatch.GNOME_VILLAGE_FRUIT]);
  Self.AddCheck(Self.TreesSection, cb, 'cb_bash_brim_fruit', 'Brimhaven', 470, y, BASHFarmConfig.Enabled[EBASHFarmPatch.BRIMHAVEN_FRUIT]);
  Self.AddCheck(Self.TreesSection, cb, 'cb_bash_lletya_fruit', 'Lletya', 590, y, BASHFarmConfig.Enabled[EBASHFarmPatch.LLETYA_FRUIT]);
  Self.AddCheck(Self.TreesSection, cb, 'cb_bash_guild_fruit', 'Guild', 690, y, BASHFarmConfig.Enabled[EBASHFarmPatch.GUILD_FRUIT]);

  Self.RefreshTreesEnabled();
end;

procedure TBASHFarmGUI.BuildShell(tab: TTabSheet);
var
  contentH, startW, startH, shellW, shellH, statusTop, statusH, mainLeft, mainW, navW, bottomInset: Int32;
begin
  // Stock Start is alBottom on the form and reserves a strip even when hidden —
  // collapse it so the page/tab can fill the window edge-to-edge.
  Self.Start.SetAlign(alNone);
  Self.Start.SetVisible(False);
  Self.Start.SetHeight(0);
  Self.Start.SetWidth(0);

  // Self.Size is already DPI-adjusted by Setup — use it for pixel layout (no second AdjustToDPI).
  bottomInset := TControl.AdjustToDPI(BASH_GUI_BOTTOM_INSET);
  navW := TControl.AdjustToDPI(BASH_GUI_NAV_W);
  statusH := TControl.AdjustToDPI(BASH_GUI_STATUS_H);
  shellW := Self.Size.X;
  shellH := Self.Size.Y;
  mainLeft := navW + TControl.AdjustToDPI(2);
  mainW := shellW - mainLeft;
  // Raise start bar into the visible client (tab/form chrome clips the true bottom)
  statusTop := shellH - statusH - bottomInset;
  contentH := statusTop;
  startW := TControl.AdjustToDPI(132);
  startH := TControl.AdjustToDPI(BASH_GUI_BTN_H);

  Self.NavPanel.Create(tab);
  Self.NavPanel.SetLeft(0);
  Self.NavPanel.SetTop(0);
  Self.NavPanel.SetWidth(navW);
  Self.NavPanel.SetHeight(shellH);
  Self.NavPanel.SetColor(BASH_GUI_NAV);
  Self.NavPanel.SetBevelOuter(bvNone);

  Self.DividerPanel.Create(tab);
  Self.DividerPanel.SetLeft(navW);
  Self.DividerPanel.SetTop(0);
  Self.DividerPanel.SetWidth(TControl.AdjustToDPI(2));
  Self.DividerPanel.SetHeight(shellH);
  Self.DividerPanel.SetColor(BASH_GUI_DIVIDER);
  Self.DividerPanel.SetBevelOuter(bvNone);

  Self.ContentPanel.Create(tab);
  Self.ContentPanel.SetLeft(mainLeft);
  Self.ContentPanel.SetTop(0);
  Self.ContentPanel.SetWidth(mainW);
  Self.ContentPanel.SetHeight(contentH);
  Self.ContentPanel.SetColor(BASH_GUI_BG);
  Self.ContentPanel.SetBevelOuter(bvNone);

  Self.StatusDivider.Create(tab);
  Self.StatusDivider.SetLeft(mainLeft);
  Self.StatusDivider.SetTop(statusTop);
  Self.StatusDivider.SetWidth(mainW);
  Self.StatusDivider.SetHeight(TControl.AdjustToDPI(2));
  Self.StatusDivider.SetColor(BASH_GUI_DIVIDER);
  Self.StatusDivider.SetBevelOuter(bvNone);

  Self.StatusPanel.Create(tab);
  Self.StatusPanel.SetLeft(mainLeft);
  Self.StatusPanel.SetTop(statusTop + Self.StatusDivider.GetHeight());
  Self.StatusPanel.SetWidth(mainW);
  Self.StatusPanel.SetHeight(statusH - Self.StatusDivider.GetHeight());
  Self.StatusPanel.SetColor(BASH_GUI_STATUS);
  Self.StatusPanel.SetBevelOuter(bvNone);

  Self.StatusPad.Create(tab);
  Self.StatusPad.SetLeft(mainLeft);
  Self.StatusPad.SetTop(Self.StatusPanel.GetTop() + Self.StatusPanel.GetHeight());
  Self.StatusPad.SetWidth(mainW);
  Self.StatusPad.SetHeight(shellH - Self.StatusPad.GetTop());
  Self.StatusPad.SetColor(BASH_GUI_STATUS);
  Self.StatusPad.SetBevelOuter(bvNone);

  Self.BrandLabel := Self.MakeLabel(Self.NavPanel, 'BASH Farm', 16, 28, 16, BASH_GUI_TEXT, True);
  Self.MakeLabel(Self.NavPanel, 'WalkerV2 runner', 16, 54, 9, BASH_GUI_MUTED, False);

  Self.PatchesNav := Self.MakeNavItem(Self.NavPanel, 'Patches', 12, 100, True);
  Self.TreesNav := Self.MakeNavItem(Self.NavPanel, 'Trees', 12, 152);
  Self.TravelNav := Self.MakeNavItem(Self.NavPanel, 'Travel', 12, 204);

  Self.PatchesSection := Self.MakePanel(Self.ContentPanel, 0, 0, 100, 100, BASH_GUI_BG);
  Self.TreesSection := Self.MakePanel(Self.ContentPanel, 0, 0, 100, 100, BASH_GUI_BG);
  Self.TravelSection := Self.MakePanel(Self.ContentPanel, 0, 0, 100, 100, BASH_GUI_BG);

  Self.PatchesSection.SetWidth(mainW);
  Self.PatchesSection.SetHeight(contentH);
  Self.TreesSection.SetWidth(mainW);
  Self.TreesSection.SetHeight(contentH);
  Self.TravelSection.SetWidth(mainW);
  Self.TravelSection.SetHeight(contentH);

  Self.BuildPatchesSection();
  Self.BuildTreesSection();
  Self.BuildTravelSection();

  Self.PatchesNav.SetOnClick(@Self.ShowPatches);
  Self.TreesNav.SetOnClick(@Self.ShowTrees);
  Self.TravelNav.SetOnClick(@Self.ShowTravel);

  Self.StartChip.Create(Self.StatusPanel);
  Self.StartChip.SetLeft(mainW - startW - TControl.AdjustToDPI(24));
  Self.StartChip.SetTop((Self.StatusPanel.GetHeight() - startH) div 2 + 2);
  Self.StartChip.SetWidth(startW);
  Self.StartChip.SetHeight(startH);
  Self.StartChip.SetCursor(crHandPoint);
  Self.PaintRoundChip(Self.StartChip, 'Start', BASH_GUI_START, BASH_GUI_STATUS, True, True);
  Self.StartChip.SetOnClick(@Self.StartScript);

  Self.ShowPatches(Self.PatchesNav);
end;

procedure TBASHFarmGUI.ApplySettings();
begin
  BASHFarmConfig.HerbSeedIdx := Self.ReadComboIdx('lcb_bash_herbseed');
  BASHFarmConfig.FlowerSeedIdx := Self.ReadComboIdx('lcb_bash_flowerseed');
  BASHFarmConfig.AllotmentSeedIdx := Self.ReadComboIdx('lcb_bash_allotseed');
  BASHFarmConfig.BushSeedIdx := Self.ReadComboIdx('lcb_bash_bushseed');
  BASHFarmConfig.CactusSeedIdx := Self.ReadComboIdx('lcb_bash_cactusseed');
  BASHFarmConfig.CompostIdx := Self.ReadComboIdx('lcb_bash_compost');

  BASHFarmConfig.WeissTP := Self.ReadComboIdx('lcb_bash_weiss_tp');
  BASHFarmConfig.StrongholdTP := Self.ReadComboIdx('lcb_bash_stronghold_tp');
  BASHFarmConfig.ArdougneTP := Self.ReadComboIdx('lcb_bash_ardougne_tp');
  BASHFarmConfig.FaladorTP := Self.ReadComboIdx('lcb_bash_falador_tp');
  BASHFarmConfig.CatherbyTP := Self.ReadComboIdx('lcb_bash_catherby_tp');
