  BASHFarmConfig.Enabled[EBASHFarmPatch.CATHERBY_FRUIT] := Self.ReadCheck('cb_bash_cath_fruit');
  BASHFarmConfig.Enabled[EBASHFarmPatch.GNOME_VILLAGE_FRUIT] := Self.ReadCheck('cb_bash_gnome_village_fruit');
  BASHFarmConfig.Enabled[EBASHFarmPatch.BRIMHAVEN_FRUIT] := Self.ReadCheck('cb_bash_brim_fruit');
  BASHFarmConfig.Enabled[EBASHFarmPatch.LLETYA_FRUIT] := Self.ReadCheck('cb_bash_lletya_fruit');
  BASHFarmConfig.Enabled[EBASHFarmPatch.GUILD_FRUIT] := Self.ReadCheck('cb_bash_guild_fruit');
  BASHFarmConfig.Enabled[EBASHFarmPatch.HARMONY_ISLAND_HERB] := False;

  BASHFarmConfig.Write();
  BASHFarmRunner.BuildFromConfig(BASHFarmConfig);
end;

procedure TBASHFarmGUI.StartScript(sender: TObject); override;
begin
  Self.ApplySettings();
  BASHFarmRunner.Init();
  WriteLn('[BASHFarm] Loaded ', Length(BASHFarmRunner.Patches), ' patches from GUI');

  // Close like base TScriptForm.StartScript — do NOT `inherited` when a host
  // still includes farmrunnerupdate (that overrides TScriptForm.StartScript and
  // reads old farm-tab controls that BASH Farm never creates).
  try
    Self._WarmBuildCache();
  except
  end;
  Self.Form.SetOnClose(nil);
  Self.Form.Close();
end;

procedure TBASHFarmGUI.Run(); override;
var
  tab: TTabSheet;
begin
  BASHFarmConfig.Read();
  Self.Setup('BASH Farm', [BASH_GUI_W, BASH_GUI_H], False);
  Self.AddTab('BASH Farm');
  tab := Self.Tabs[High(Self.Tabs)];
  Self.BuildShell(tab); // reparents/styles Start after Setup creates it
  inherited;
end;
