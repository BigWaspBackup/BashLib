  Self.AddCheck(Self.PatchesSection, cb, 'cb_bash_ortus_flower', 'Flower', 230, y, BASHFarmConfig.Enabled[EBASHFarmPatch.ORTUS_FLOWER]);
  Self.AddCheck(Self.PatchesSection, cb, 'cb_bash_ortus_allot', 'Allotments', 340, y,
    BASHFarmConfig.Enabled[EBASHFarmPatch.ORTUS_ALLOT_N] or BASHFarmConfig.Enabled[EBASHFarmPatch.ORTUS_ALLOT_S]);

  y := 565;
  Self.MakeLabel(Self.PatchesSection, 'Guild', 24, y, 10, BASH_GUI_TEXT, False);
  Self.AddCheck(Self.PatchesSection, cb, 'cb_bash_guild_herb', 'Herb', 140, y, BASHFarmConfig.Enabled[EBASHFarmPatch.GUILD_HERB]);
  Self.AddCheck(Self.PatchesSection, cb, 'cb_bash_guild_flower', 'Flower', 230, y, BASHFarmConfig.Enabled[EBASHFarmPatch.GUILD_FLOWER]);
  Self.AddCheck(Self.PatchesSection, cb, 'cb_bash_guild_allot', 'Allotments', 340, y,
