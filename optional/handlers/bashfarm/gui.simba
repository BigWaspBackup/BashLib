  BASHFarmConfig.Enabled[EBASHFarmPatch.GUILD_ANIMA] := False;

  BASHFarmConfig.Enabled[EBASHFarmPatch.LUMBRIDGE_TREE] := Self.ReadCheck('cb_bash_lum_tree');
