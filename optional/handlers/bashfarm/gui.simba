  Self.AddCheck(Self.PatchesSection, cb, 'cb_bash_guild_bush', 'Bush', 470, y, BASHFarmConfig.Enabled[EBASHFarmPatch.GUILD_BUSH]);
  Self.AddCheck(Self.PatchesSection, cb, 'cb_bash_guild_cactus', 'Cactus', 550, y, BASHFarmConfig.Enabled[EBASHFarmPatch.GUILD_CACTUS]);

  Self.RefreshPatchesEnabled();
end;

procedure TBASHFarmGUI.BuildTravelSection();
var
  lcb: TLabeledComboBox;
  cb: TLabeledCheckBox;
begin
  Self.AddHeader(Self.TravelSection, 'Travel', 'Teleports for enabled patches with a seed or sapling selected. Unused options are greyed out.');

  Self.MakeLabel(Self.TravelSection, 'Herb / flower / allotment', 24, 96, 11, BASH_GUI_TEXT, True);

  Self.AddCombo(Self.TravelSection, lcb, 'lcb_bash_weiss_tp', 'Weiss', 24, 116, BASH_TRAVEL_WEISS, BASHFarmConfig.WeissTP);
  Self.AddCombo(Self.TravelSection, lcb, 'lcb_bash_stronghold_tp', 'Stronghold', BASH_GUI_COMBO_COL2, 116, BASH_TRAVEL_STRONGHOLD, BASHFarmConfig.StrongholdTP);
  Self.AddCombo(Self.TravelSection, lcb, 'lcb_bash_ardougne_tp', 'Ardougne', BASH_GUI_COMBO_COL3, 116, BASH_TRAVEL_ARDOUGNE, BASHFarmConfig.ArdougneTP);

  Self.AddCombo(Self.TravelSection, lcb, 'lcb_bash_falador_tp', 'Falador', 24, 178, BASH_TRAVEL_FALADOR, BASHFarmConfig.FaladorTP);
  Self.AddCombo(Self.TravelSection, lcb, 'lcb_bash_catherby_tp', 'Catherby', BASH_GUI_COMBO_COL2, 178, BASH_TRAVEL_CATHERBY, BASHFarmConfig.CatherbyTP);
  // Phasmatys / Mory: Ectophial only — no travel combo

  Self.AddCombo(Self.TravelSection, lcb, 'lcb_bash_hosidius_tp', 'Hosidius', BASH_GUI_COMBO_COL3, 178, BASH_TRAVEL_HOSIDIUS, BASHFarmConfig.HosidiusTP);
  Self.AddCombo(Self.TravelSection, lcb, 'lcb_bash_ortus_tp', 'Civitas illa Fortis', 24, 240, BASH_TRAVEL_ORTUS, BASHFarmConfig.OrtusTP);
  Self.AddCombo(Self.TravelSection, lcb, 'lcb_bash_guild_tp', 'Farming Guild', BASH_GUI_COMBO_COL2, 240, BASH_TRAVEL_GUILD, BASHFarmConfig.GuildTP);
  lcb.ComboBox.SetOnChange(@Self.OnSeedComboChange);
  // Directly under Farming Guild dropdown — only shown for Fairy CIR
  Self.AddCheck(Self.TravelSection, cb, 'cb_bash_lumby_elite', 'Lumby elite (no Dramen)', BASH_GUI_COMBO_COL2, 302, BASHFarmConfig.LumbyElite);

  Self.MakeLabel(Self.TravelSection, 'Trees', 24, 336, 11, BASH_GUI_TEXT, True);

  Self.AddCombo(Self.TravelSection, lcb, 'lcb_bash_lum_tree_tp', 'Lumbridge tree', 24, 356, BASH_TRAVEL_LUMBRIDGE_TREE, BASHFarmConfig.LumbridgeTreeTP);
  Self.AddCombo(Self.TravelSection, lcb, 'lcb_bash_var_tree_tp', 'Varrock tree', BASH_GUI_COMBO_COL2, 356, BASH_TRAVEL_VARROCK_TREE, BASHFarmConfig.VarrockTreeTP);
  Self.AddCombo(Self.TravelSection, lcb, 'lcb_bash_fally_tree_tp', 'Falador tree', BASH_GUI_COMBO_COL3, 356, BASH_TRAVEL_FALADOR_TREE, BASHFarmConfig.FaladorTreeTP);

  Self.AddCombo(Self.TravelSection, lcb, 'lcb_bash_tav_tree_tp', 'Taverley tree', 24, 418, BASH_TRAVEL_TAVERLEY_TREE, BASHFarmConfig.TaverleyTreeTP);
  Self.AddCombo(Self.TravelSection, lcb, 'lcb_bash_gnome_tree_tp', 'Gnome tree', BASH_GUI_COMBO_COL2, 418, BASH_TRAVEL_GNOME_TREE, BASHFarmConfig.GnomeTreeTP);

  Self.MakeLabel(Self.TravelSection, 'Fruit trees', 24, 484, 11, BASH_GUI_TEXT, True);

  Self.AddCombo(Self.TravelSection, lcb, 'lcb_bash_gnome_fruit_tp', 'Gnome fruit', 24, 504, BASH_TRAVEL_GNOME_FRUIT, BASHFarmConfig.GnomeFruitTP);
  Self.AddCombo(Self.TravelSection, lcb, 'lcb_bash_gnome_village_tp', 'Gnome village fruit', BASH_GUI_COMBO_COL2, 504, BASH_TRAVEL_GNOME_VILLAGE_FRUIT, BASHFarmConfig.GnomeVillageFruitTP);
  Self.AddCombo(Self.TravelSection, lcb, 'lcb_bash_cath_fruit_tp', 'Catherby fruit', BASH_GUI_COMBO_COL3, 504, BASH_TRAVEL_CATHERBY_FRUIT, BASHFarmConfig.CatherbyFruitTP);

  Self.AddCombo(Self.TravelSection, lcb, 'lcb_bash_brim_fruit_tp', 'Brimhaven fruit', 24, 566, BASH_TRAVEL_BRIMHAVEN_FRUIT, BASHFarmConfig.BrimhavenFruitTP);
  Self.AddCombo(Self.TravelSection, lcb, 'lcb_bash_lletya_fruit_tp', 'Lletya fruit', BASH_GUI_COMBO_COL2, 566, BASH_TRAVEL_LLETYA_FRUIT, BASHFarmConfig.LletyaFruitTP);

  Self.RefreshTravelEnabled();
end;

procedure TBASHFarmGUI.BuildTreesSection();
