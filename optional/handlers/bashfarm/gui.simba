  Self.AddCheck(Self.TreesSection, cb, 'cb_bash_gnome_tree', 'Gnome', 470, y, BASHFarmConfig.Enabled[EBASHFarmPatch.GNOME_TREE]);
  Self.AddCheck(Self.TreesSection, cb, 'cb_bash_guild_tree', 'Guild', 570, y, BASHFarmConfig.Enabled[EBASHFarmPatch.GUILD_TREE]);
  Self.AddCheck(Self.TreesSection, cb, 'cb_bash_guild_redwood', 'Redwood', 660, y, BASHFarmConfig.Enabled[EBASHFarmPatch.GUILD_REDWOOD]);

  Self.MakeLabel(Self.TreesSection, 'Fruit trees', 24, 250, 11, BASH_GUI_TEXT, True);
