var
  BASHFarmPatchDataReady: Boolean = False;

procedure EnsureBASHFarmPatchData();
begin
  if BASHFarmPatchDataReady then
    Exit;
  _InitBASHFarmPatchData();
  BASHFarmPatchDataReady := True;
end;
