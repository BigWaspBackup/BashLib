(*!
  Static patch definitions for BASHFarmRunner.
  Coordinates are WalkerV2 / RSTeleportsV2 space.
  Fine-tune with getobjectv2 if a walk-to point is slightly off; color Find() is primary once on-site.
*)

// Stony basalt without Frem hard diary lands below the rocks (73 Agility to climb).
const
  BASH_STRONGHOLD_ROCKS: TPoint = [7275, 35656];
  BASH_STRONGHOLD_SHORTCUT_BOTTOM: TPoint = [7280, 35658];
  BASH_STRONGHOLD_SHORTCUT_TOP: TPoint = [7256, 35658];

  // Farming guild — pick nearest lep per patch
  BASH_GUILD_LEP_SE: TPoint = [952, 35506];
  BASH_GUILD_LEP_SW: TPoint = [848, 35502];
  BASH_GUILD_LEP_NE: TPoint = [912, 35406];
  BASH_GUILD_COMPOST_BIN: TPoint = [993, 35511];

  // Ortus Farm (Civitas illa Fortis) — WalkerV2 coords collected
  BASH_ORTUS_HUNTER_LANDING: TPoint = [2276, 38180]; // south of farm; run north to patches
  BASH_ORTUS_LEP: TPoint = [2276, 38034];
  BASH_ORTUS_HERB: TPoint = [2230, 38052];
  BASH_ORTUS_FLOWER: TPoint = [2246, 38036];
  BASH_ORTUS_ALLOT_N: TPoint = [2233, 38025];
  BASH_ORTUS_ALLOT_S: TPoint = [2257, 38049];
  BASH_ORTUS_MAP: TBox = [2128, 37918, 2366, 38154];

var
  BASHFarmPatchData: array [EBASHFarmPatch] of TBASHPatchData;

function _BASHChunks(chunks: array of TRSMapChunk): array of TRSMapChunk;
begin
  Result := chunks;
end;

// Placeholder entry — fill Coords / Outline / colors when collecting data.
procedure _BASHStub(id: EBASHFarmPatch; ptype: EBASHPatchType; name, farmer: String);
begin
  BASHFarmPatchData[id] := [
    ptype,
    CTS2(0, 0, 0, 0),
    CTS2(0, 0, 0, 0),
    [0, 0],
    [0, 0],
    CTS2(0, 0, 0, 0),
    name,
    [0, 0, 0, 0],
    farmer,
    CTS2(0, 0, 0, 0),
    _BASHChunks([])
  ];
end;

